# Fakebook local environment — copy to .env and fill in real values.
# .env is gitignored; this template (.env.example) is committed.
# Consumed by the Aspire AppHost / dev tooling. Do not put production secrets here.

# --- PostgreSQL (planned: wire in AppHost.cs via Aspire.Hosting.PostgreSQL) ---
POSTGRES_USER=fakebook
POSTGRES_PASSWORD=change-me-local-dev
POSTGRES_DB=fakebook

# --- Auth (planned) ---
# JWT signing key. Generate a strong random value for any non-local env.
JWT_SECRET=change-me-local-dev

# --- Aspire ---
# Uncomment only if running the dashboard without HTTPS locally.
# ASPIRE_ALLOW_UNSECURED_TRANSPORT=true
